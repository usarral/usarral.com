---
import type { GetStaticPaths } from "astro";
import { isLocale, type Locale, locales } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";
import PageLayout from "@/layouts/Base.astro";

export const getStaticPaths = (() => {
	return locales.map((lang) => ({ params: { lang } }));
}) satisfies GetStaticPaths;

const { lang } = Astro.params;
if (!isLocale(lang)) throw new Error(`Invalid locale: ${lang}`);
const locale: Locale = lang;
const t = useTranslations(locale);

const meta = {
	description: t("404.description"),
	title: t("404.metaTitle"),
};
---

<PageLayout meta={meta} locale={locale}>
	<h1 class="title mb-12">{t("404.title")}</h1>
	<p class="mb-8">{t("404.message")}</p>
	<p>
		<a class="cactus-link" href={`/${locale}/`}>{t("404.home")}</a>
	</p>
</PageLayout>
