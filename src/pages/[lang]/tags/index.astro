---
import type { GetStaticPaths } from "astro";
import { getPostsByLocale, getUniqueTagsWithCount } from "@/data/post";
import { isLocale, type Locale, locales } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";
import PageLayout from "@/layouts/Base.astro";

export const getStaticPaths = (() => {
	return locales.map((lang) => ({ params: { lang } }));
}) satisfies GetStaticPaths;

const { lang } = Astro.params;
if (!isLocale(lang)) throw new Error(`Invalid locale: ${lang}`);
const locale: Locale = lang;
const t = useTranslations(locale);

const allPosts = await getPostsByLocale(locale);
const allTags = getUniqueTagsWithCount(allPosts);

const meta = {
	description: t("tags.pageDescription"),
	title: t("tags.title"),
};
---

<PageLayout meta={meta} locale={locale}>
	<h1 class="title mb-6">{t("tags.title")}</h1>
	<ul class="space-y-4">
		{
			allTags.map(([tag, val]) => (
				<li class="flex items-center gap-x-2">
					<a
						class="cactus-link inline-block"
						href={`/${locale}/tags/${tag}/`}
						title={`${t("tags.viewPostsWithTag")} ${tag}`}
					>
						&#35;{tag}
					</a>
					<span class="inline-block">
						- {val} {val > 1 ? t("tags.posts") : t("tags.post")}
					</span>
				</li>
			))
		}
	</ul>
</PageLayout>
