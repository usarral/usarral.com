---
import { render } from "astro:content";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import { Icon } from "astro-icon/components";
import PostPreview from "@/components/blog/PostPreview.astro";
import Pagination from "@/components/Paginator.astro";
import { getPostsByLocale, getTagMeta, getUniqueTags } from "@/data/post";
import { isLocale, type Locale, locales } from "@/i18n/config";
import { useTranslations } from "@/i18n/utils";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";

export const getStaticPaths = (async ({ paginate }) => {
	const results = await Promise.all(
		locales.map(async (lang) => {
			const allPosts = await getPostsByLocale(lang);
			const sortedPosts = allPosts.sort(collectionDateSort);
			const uniqueTags = getUniqueTags(sortedPosts);

			return uniqueTags.flatMap((tag) => {
				const postsWithTag = sortedPosts.filter((post) => post.data.tags.includes(tag));
				return paginate(postsWithTag, {
					pageSize: 10,
					params: { lang, tag },
					props: { locale: lang },
				});
			});
		}),
	);
	return results.flat();
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { page, locale } = Astro.props as Props;
const { tag, lang } = Astro.params;
if (!isLocale(lang)) throw new Error(`Invalid locale: ${lang}`);
const localeParam: Locale = locale ?? lang;
const t = useTranslations(localeParam);

const tagMeta = await getTagMeta(tag);
const TagContent = tagMeta ? (await render(tagMeta)).Content : null;

const meta = {
	description: tagMeta?.data.description ?? `${t("tags.viewAllPostsWithTag")} ${tag}`,
	title: tagMeta?.data.title ?? `${t("tags.postsAbout")} ${tag}`,
};

const paginationProps = {
	...(page.url.prev && {
		prevUrl: {
			text: t("tags.prevTags"),
			url: page.url.prev,
		},
	}),
	...(page.url.next && {
		nextUrl: {
			text: t("tags.nextTags"),
			url: page.url.next,
		},
	}),
};
---

<PageLayout meta={meta} locale={localeParam}>
	<nav class="mb-8" aria-label="Breadcrumbs">
		<ul class="flex items-center">
			<li class="flex items-center">
				<a class="text-accent" href={`/${localeParam}/tags/`}>{t("tags.breadcrumbsTags")}</a>
				<Icon aria-hidden="true" name="mdi:chevron-right" class="mx-1.5" />
			</li>
			<li aria-current="page" class=""><span aria-hidden="true">#</span>{tag}</li>
		</ul>
	</nav>
	<h1 class="title capitalize">{tagMeta?.data.title ?? `${t("tags.postsAbout")} ${tag}`}</h1>
	<div class="prose prose-sm prose-cactus mb-16 max-w-none">
		{tagMeta?.data.description && <p>{tagMeta.data.description}</p>}
		{TagContent && <TagContent />}
	</div>
	<ul class="space-y-4">
		{
			page.data.map((p) => (
				<li class="grid gap-1 sm:grid-cols-[auto_1fr]">
					<PostPreview as="h2" post={p} locale={localeParam} />
				</li>
			))
		}
	</ul>
	<Pagination {...paginationProps} />
</PageLayout>
