---
import { siteConfig } from "@/site.config";

const title = siteConfig.title;
const description = siteConfig.description;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta content="width=device-width, initial-scale=1.0" name="viewport" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="alternate" hreflang="en" href="/en/" />
		<link rel="alternate" hreflang="es" href="/es/" />
		<link rel="alternate" hreflang="x-default" href="/en/" />
		<link rel="canonical" href="/en/" />
		<meta name="robots" content="noindex" />
		<link href="/icon.svg" rel="icon" type="image/svg+xml" />
		<link href="https://github.com/usarral" rel="me" />
		<link href="https://webmention.io/usarral.com/webmention" rel="webmention" />
		<link href="https://webmention.io/usarral.com/xmlrpc" rel="pingback" />
		<script is:inline>
			(() => {
				try {
					const COOKIE = "lang";
					const supported = ["en", "es"];
					const cookie = document.cookie.split("; ").find((c) => c.startsWith(COOKIE + "="));
					const stored = cookie ? decodeURIComponent(cookie.split("=")[1]) : null;
					const nav = (navigator.languages && navigator.languages[0]) || navigator.language || "en";
					const browser = nav.toLowerCase().startsWith("es") ? "es" : "en";
					const target = supported.indexOf(stored) !== -1 ? stored : browser;
					const params = window.location.search || "";
					const hash = window.location.hash || "";
					window.location.replace("/" + target + "/" + params + hash);
				} catch (e) {
					window.location.replace("/en/");
				}
			})();
		</script>
		<meta http-equiv="refresh" content="0; url=/en/" />
	</head>
	<body>
		<p>
			<a href="/en/">English</a> ·
			<a href="/es/">Español</a>
		</p>
	</body>
</html>
