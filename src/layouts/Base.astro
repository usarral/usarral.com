---
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import BaseHead from "@/components/BaseHead.astro";
import Footer from "@/components/layout/Footer.astro";
import Header from "@/components/layout/Header.astro";
import SkipLink from "@/components/SkipLink.astro";
import ThemeProvider from "@/components/ThemeProvider.astro";
import type { Locale } from "@/i18n/config";
import { ui } from "@/i18n/ui";
import { getLocaleFromUrl } from "@/i18n/utils";
import type { SiteMeta } from "@/types";

interface Props {
	meta: SiteMeta;
	locale?: Locale;
	alternateUrls?: Partial<Record<Locale, string>>;
}

const { meta, locale: localeProp, alternateUrls } = Astro.props;
const locale = localeProp ?? getLocaleFromUrl(Astro.url);
const description = meta.description ?? ui[locale]["site.description"];
const htmlLang = locale === "es" ? "es-ES" : "en-US";
---

<html class="scroll-smooth" lang={htmlLang}>
	<head>
		<ThemeProvider />
		<BaseHead
			articleDate={meta.articleDate}
			description={description}
			ogImage={meta.ogImage}
			title={meta.title}
			locale={locale}
			{...(alternateUrls && { alternateUrls })}
		/>
	</head>
	<body
		class="bg-global-bg text-global-text mx-auto flex min-h-screen max-w-3xl flex-col px-4 pt-16 font-mono text-sm font-normal antialiased sm:px-8"
	>
		<SkipLink />
		<Header locale={locale} />
		<main id="main">
			<slot />
		</main>
		<Footer locale={locale} />
		<Analytics />
		<SpeedInsights />
		<script is:inline type="speculationrules">
			{
				"prefetch": [
					{
						"where": {
							"href_matches": "/*"
						},
						"eagerness": "immediate"
					}
				],
				"prerender": [
					{
						"where": {
							"href_matches": "/*"
						},
						"eagerness": "moderate"
					}
				]
			}
		</script>
	</body>
</html>
